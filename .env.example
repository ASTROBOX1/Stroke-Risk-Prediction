# Environment Configuration for Stroke Prediction Analytics
# Copy this file to .env and modify values as needed

# App Configuration
APP_NAME=Stroke Prediction Analytics Platform
APP_VERSION=2.1.0
ENV=development

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Data Paths
DATA_PATH=data/healthcare-dataset-stroke-data.csv
MODEL_DIR=models

# Model Configuration
MODEL_FILE=best_stroke_model.joblib
METRICS_FILE=metrics.json
FEATURE_IMPORTANCE_FILE=feature_importance.json

# Streamlit Configuration
STREAMLIT_PORT=8501
STREAMLIT_SERVER_HEADLESS=false

# FastAPI Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true
API_WORKERS=4

# CORS Configuration (comma-separated list of allowed origins)
# In production, set to specific domains only
CORS_ORIGINS=http://localhost:8501,http://localhost:3000,http://127.0.0.1:8501

# Database (Future)
DATABASE_URL=sqlite:///./app.db

# Security & Rate Limiting
API_RATE_LIMIT=100/minute
SECRET_KEY=change-this-in-production-to-random-secret-key

